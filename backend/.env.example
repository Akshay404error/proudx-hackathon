# PathForge Configuration
APP_NAME=PathForge
APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-string-in-production
DATABASE_URL=sqlite:///./pathforge.db

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# ---------- EMAIL (Gmail SMTP for OTP) ----------
# Mode: gmail | console
# - gmail   : sends real emails via Gmail SMTP (requires app password)
# - console : prints OTP to terminal (great for hackathon demo / dev)
EMAIL_MODE=console

# Required ONLY if EMAIL_MODE=gmail
# Step 1: Enable 2-Step Verification on your Google account
# Step 2: Generate an App Password: https://myaccount.google.com/apppasswords
# Step 3: Paste the 16-char password below (no spaces)
GMAIL_USER=akshay2005air@gmail.com
GMAIL_APP_PASSWORD=tlzd dadx brjw sedc
EMAIL_FROM_NAME=PathForge

# OTP behavior
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_15MIN=3
